<!DOCTYPE html>
<html lang="id">
<head>
    <title>Smart Trash Itenas</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
    <h2 class="text-center">Sistem Monitoring Sampah - <%= process.env.DB_NAME %></h2>
    
    <div class="card p-4 mb-4">
        <h4>Lapor Sampah Liar</h4>
        <form action="/report" method="POST" enctype="multipart/form-data">
            <input type="text" name="description" class="form-control mb-2" placeholder="Deskripsi lokasi..." required>
            <input type="file" name="photo" class="form-control mb-2" required>
            <button type="submit" class="btn btn-primary w-100">Kirim Laporan</button>
        </form>
    </div>

    <h4>Daftar Laporan</h4>
    <div class="row">
        <% laporan.forEach(l => { %>
            <div class="col-md-4 mb-3">
                <div class="card">
                    <img src="<%= l.image_url %>" class="card-img-top">
                    <div class="card-body"><p><%= l.description %></p></div>
                </div>
            </div>
        <% }) %>
    </div>
</body>
</html>